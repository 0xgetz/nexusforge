{
  "name": "@nexusforge/testgen",
  "version": "0.1.0",
  "description": "NexusForge AI Test Generator — Smart test generation, coverage analysis, and mutation testing",
  "type": "module",
  "bin": {
    "nxf-test": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./analyzer": "./dist/analyzer.js",
    "./generator": "./dist/generator.js",
    "./coverage": "./dist/coverage.js",
    "./mutator": "./dist/mutator.js",
    "./frameworks": "./dist/frameworks.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/analyzer.ts src/generator.ts src/coverage.ts src/mutator.ts src/frameworks.ts src/prompts.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "start": "node dist/index.js"
  },
  "keywords": ["test-generation", "ai", "coverage", "mutation-testing", "vitest", "jest", "pytest"],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.0.1",
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "tsup": "^8.2.0",
    "typescript": "^6.0.2",
    "@types/node": "^25.6.0"
  }
}