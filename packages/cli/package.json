{
  "name": "@nexusforge/cli",
  "version": "0.1.0",
  "description": "NexusForge AI Coding Assistant — Interactive CLI with multi-model support",
  "type": "module",
  "bin": {
    "nexusforge": "./dist/index.js",
    "nxf": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "start": "node dist/index.js"
  },
  "keywords": ["ai", "coding-assistant", "cli", "llm", "code-generation"],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "inquirer": "^9.3.0",
    "ora": "^8.0.1",
    "marked": "^17.0.6",
    "marked-terminal": "^7.1.0",
    "highlight.js": "^11.10.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^22.0.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0"
  }
}