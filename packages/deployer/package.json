{
  "name": "@nexusforge/deployer",
  "version": "0.1.0",
  "description": "NexusForge Smart Deployer — Multi-cloud deployment, IaC generation, CI/CD pipeline builder",
  "type": "module",
  "bin": {
    "nxf-deploy": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./detector": "./dist/detector.js",
    "./builder": "./dist/builder.js",
    "./iac": "./dist/iac.js",
    "./pipeline": "./dist/pipeline.js",
    "./rollback": "./dist/rollback.js",
    "./health": "./dist/health.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/detector.ts src/builder.ts src/iac.ts src/pipeline.ts src/rollback.ts src/health.ts src/providers/vercel.ts src/providers/netlify.ts src/providers/aws.ts src/providers/gcp.ts src/providers/docker.ts src/providers/custom.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "start": "node dist/index.js"
  },
  "keywords": ["deployment", "ci-cd", "infrastructure", "iac", "multi-cloud", "docker", "vercel", "aws"],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.0.1",
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "tsup": "^8.2.0",
    "typescript": "^6.0.2",
    "@types/node": "^25.6.0"
  }
}